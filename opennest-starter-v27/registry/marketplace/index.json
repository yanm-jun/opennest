[
  {
    "schemaVersion": "2.0.0",
    "id": "n8n",
    "name": "n8n",
    "summary": "开源自动化工作流引擎，可视化的 Zapier/Make 替代品",
    "description": "n8n 是一个可自托管的可视化工作流自动化平台。通过 Docker Compose 一键部署。",
    "runtime": "docker-compose",
    "category": "自动化",
    "versionSource": "docker:n8nio/n8n:latest",
    "homepage": "https://n8n.io",
    "ports": [5678],
    "tags": ["workflow", "automation", "low-code"],
    "start": {
      "strategy": "docker-compose",
      "args": ["up", "-d"],
      "healthcheck": "http://127.0.0.1:5678/"
    },
    "stop": { "strategy": "docker-compose", "args": ["stop"] },
    "dashboard": { "strategy": "url", "url": "http://127.0.0.1:5678/" },
    "logs": { "strategy": "docker-compose-logs", "tail": 200 },
    "requirements": { "docker": true, "memoryGbRecommended": 4 },
    "secrets": []
  },
