{
  "runtimeType": "native-cli",
  "versionSource": "npm:openclaw@latest",
  "license": "upstream",
  "paths": {
    "appDir": "${openNestAppData}/apps/openclaw",
    "cliDir": "${appDir}/cli",
    "stateDir": "${appDir}/state",
    "configDir": "${appDir}/config",
    "logsDir": "${appDir}/logs"
  },
  "install": {
    "strategy": "npm-global-prefix",
    "package": "openclaw@latest",
    "prefix": "${appDir}/cli",
    "binaryWindows": "${appDir}/cli/openclaw.cmd"
  },
  "onboarding": {
    "strategy": "terminal",
    "command": "${binary}",
    "args": ["onboard", "--install-daemon"]
  },
  "start": {
    "strategy": "official-gateway-controller",
    "command": "${binary}",
    "args": ["gateway", "start"],
    "healthcheck": "tcp://127.0.0.1:18789"
  },
  "stop": {
    "strategy": "official-gateway-controller",
    "command": "${binary}",
    "args": ["gateway", "stop"]
  },
  "dashboard": {
    "strategy": "command-then-url",
    "command": "${binary}",
    "args": ["dashboard"],
    "fallbackUrl": "http://127.0.0.1:18789/"
  },
  "doctor": {
    "command": "${binary}",
    "args": ["doctor", "--non-interactive"]
  },
  "logs": {
    "path": "${appDir}/logs/openclaw.log",
    "tail": 200
  },
  "secrets": [
    { "id": "deepseekApiToken", "label": "DeepSeek API Token", "required": false, "redact": true },
    { "id": "openaiApiToken", "label": "OpenAI API Token", "required": false, "redact": true },
    { "id": "anthropicApiToken", "label": "Anthropic API Token", "required": false, "redact": true },
    { "id": "geminiApiToken", "label": "Google Gemini API Token", "required": false, "redact": true },
    { "id": "openrouterApiToken", "label": "OpenRouter API Token", "required": false, "redact": true }
  ],
  "permissions": [
    { "type": "network", "level": "local", "description": "Starts a local dashboard on 127.0.0.1:18789." },
    { "type": "secrets", "level": "model-provider", "description": "Injects selected model provider token only at process runtime." }
  ]
}
