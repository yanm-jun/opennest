{
  "schemaVersion": "1.0.0",
  "id": "dify",
  "name": "Dify",
  "summary": "Self-host Dify through its official Docker Compose setup.",
  "description": "Dify is a large multi-service stack. OpenNest should use external-compose strategy instead of hand-maintaining a huge compose file.",
  "runtime": "external-compose",
  "category": "Agentic Workflow Platform",
  "versionSource": "github:langgenius/dify/docker",
  "homepage": "https://github.com/langgenius/dify",
  "license": "upstream",
  "ports": [
    80
  ],
  "requirements": {
    "docker": true,
    "memoryGbRecommended": 8,
    "cpuRecommended": 2,
    "network": true
  },
  "paths": {
    "appDir": "${openNestAppData}/apps/dify",
    "repoDir": "${appDir}/source",
    "composeDir": "${appDir}/source/docker",
    "logsDir": "${appDir}/logs"
  },
  "install": {
    "strategy": "clone-official-compose",
    "repo": "https://github.com/langgenius/dify.git",
    "composeDir": "docker",
    "envExample": ".env.example",
    "envTarget": ".env",
    "ref": "main"
  },
  "start": {
    "strategy": "docker-compose",
    "workingDir": "${composeDir}",
    "args": [
      "up",
      "-d"
    ],
    "healthcheck": "http://127.0.0.1/"
  },
  "stop": {
    "strategy": "docker-compose",
    "workingDir": "${composeDir}",
    "args": [
      "stop"
    ]
  },
  "dashboard": {
    "strategy": "url",
    "url": "http://127.0.0.1/"
  },
  "logs": {
    "strategy": "docker-compose-logs",
    "workingDir": "${composeDir}",
    "tail": 200
  },
  "secrets": [],
  "permissions": [
    {
      "type": "network",
      "level": "local",
      "description": "Runs a multi-container local Dify stack."
    },
    {
      "type": "storage",
      "level": "app-data",
      "description": "Stores Dify source, compose files, database volumes, and logs in OpenNest app data."
    }
  ]
}
