{
  "schemaVersion": "1.0.0",
  "id": "flowise",
  "name": "Flowise",
  "summary": "Build AI agents visually and run Flowise locally.",
  "description": "Flowise runs through Docker Compose. OpenNest writes the compose file and manages lifecycle.",
  "runtime": "docker-compose",
  "category": "Visual Agent Builder",
  "versionSource": "docker:flowiseai/flowise:latest",
  "homepage": "https://github.com/FlowiseAI/Flowise",
  "license": "upstream",
  "ports": [
    3001
  ],
  "requirements": {
    "docker": true,
    "memoryGbRecommended": 4,
    "network": true
  },
  "paths": {
    "appDir": "${openNestAppData}/apps/flowise",
    "composePath": "${appDir}/docker-compose.yml",
    "logsDir": "${appDir}/logs"
  },
  "install": {
    "strategy": "write-compose",
    "source": "recipes/flowise/docker-compose.yml"
  },
  "start": {
    "strategy": "docker-compose",
    "args": [
      "up",
      "-d"
    ],
    "healthcheck": "http://127.0.0.1:3001/"
  },
  "stop": {
    "strategy": "docker-compose",
    "args": [
      "stop"
    ]
  },
  "dashboard": {
    "strategy": "url",
    "url": "http://127.0.0.1:3001/"
  },
  "logs": {
    "strategy": "docker-compose-logs",
    "tail": 200
  },
  "secrets": [],
  "permissions": [
    {
      "type": "network",
      "level": "local",
      "description": "Opens a local web UI on 127.0.0.1:3001."
    }
  ]
}