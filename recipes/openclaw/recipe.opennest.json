{
  "schemaVersion": "1.0.0",
  "id": "openclaw",
  "name": "OpenClaw",
  "summary": "Run OpenClaw locally with one-click setup.",
  "description": "OpenClaw is a local AI assistant gateway. OpenNest manages install, secrets, gateway lifecycle, logs, and dashboard opening.",
  "runtime": "native-cli",
  "category": "Local AI Assistant",
  "versionSource": "npm:openclaw@latest",
  "homepage": "https://github.com/openclaw/openclaw",
  "license": "upstream",
  "ports": [
    18789
  ],
  "requirements": {
    "os": [
      "windows"
    ],
    "node": {
      "recommended": "24.x",
      "minimum": "22.16.0"
    },
    "network": true
  },
  "paths": {
    "appDir": "${openNestAppData}/apps/openclaw",
    "cliDir": "${appDir}/cli",
    "stateDir": "${appDir}/state",
    "configDir": "${appDir}/config",
    "logsDir": "${appDir}/logs"
  },
  "install": {
    "strategy": "npm-global-prefix",
    "package": "openclaw@latest",
    "prefix": "${appDir}/cli",
    "binaryWindows": "${appDir}/cli/openclaw.cmd"
  },
  "onboarding": {
    "strategy": "terminal",
    "command": "${binary}",
    "args": [
      "onboard",
      "--install-daemon"
    ],
    "description": "Open official OpenClaw onboarding in a terminal window when automatic startup is not enough."
  },
  "start": {
    "strategy": "child-process",
    "command": "${binary}",
    "args": [
      "gateway",
      "--port",
      "18789",
      "--verbose"
    ],
    "healthcheck": "http://127.0.0.1:18789/",
    "env": {
      "OPENCLAW_HOME": "${appDir}",
      "OPENCLAW_STATE_DIR": "${appDir}/state",
      "OPENCLAW_CONFIG_PATH": "${appDir}/config/openclaw.json",
      "OPENAI_API_KEY": "${secrets.openaiApiToken}",
      "ANTHROPIC_API_KEY": "${secrets.anthropicApiToken}",
      "GEMINI_API_KEY": "${secrets.geminiApiToken}",
      "OPENROUTER_API_KEY": "${secrets.openrouterApiToken}"
    }
  },
  "stop": {
    "strategy": "tracked-pid-only"
  },
  "dashboard": {
    "strategy": "command-then-url",
    "command": "${binary}",
    "args": [
      "dashboard"
    ],
    "fallbackUrl": "http://127.0.0.1:18789/"
  },
  "doctor": {
    "command": "${binary}",
    "args": [
      "doctor"
    ]
  },
  "logs": {
    "path": "${appDir}/logs/openclaw.log",
    "tail": 200
  },
  "secrets": [
    {
      "id": "openaiApiToken",
      "label": "OpenAI API Token",
      "provider": "openai",
      "required": false,
      "store": "system-credential-store",
      "redact": true
    },
    {
      "id": "anthropicApiToken",
      "label": "Anthropic API Token",
      "provider": "anthropic",
      "required": false,
      "store": "system-credential-store",
      "redact": true
    },
    {
      "id": "geminiApiToken",
      "label": "Google Gemini API Token",
      "provider": "google-gemini",
      "required": false,
      "store": "system-credential-store",
      "redact": true
    },
    {
      "id": "openrouterApiToken",
      "label": "OpenRouter API Token",
      "provider": "openrouter",
      "required": false,
      "store": "system-credential-store",
      "redact": true
    }
  ],
  "permissions": [
    {
      "type": "network",
      "level": "local",
      "description": "Starts a local dashboard on 127.0.0.1:18789."
    },
    {
      "type": "secrets",
      "level": "model-provider",
      "description": "Injects selected model provider token only at process runtime."
    }
  ]
}