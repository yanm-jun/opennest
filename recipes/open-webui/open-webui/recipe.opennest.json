{
  "schemaVersion": "1.0.0",
  "id": "open-webui",
  "name": "Open WebUI",
  "summary": "Run Open WebUI locally through Docker Compose.",
  "description": "A local web UI for AI models. OpenNest manages Docker Compose lifecycle and opens the dashboard.",
  "runtime": "docker-compose",
  "category": "AI Chat UI",
  "versionSource": "docker:ghcr.io/open-webui/open-webui:main",
  "homepage": "https://github.com/open-webui/open-webui",
  "license": "upstream",
  "ports": [
    3000
  ],
  "requirements": {
    "docker": true,
    "memoryGbRecommended": 4,
    "network": true
  },
  "paths": {
    "appDir": "${openNestAppData}/apps/open-webui",
    "composePath": "${appDir}/docker-compose.yml",
    "logsDir": "${appDir}/logs"
  },
  "install": {
    "strategy": "write-compose",
    "source": "recipes/open-webui/docker-compose.yml"
  },
  "start": {
    "strategy": "docker-compose",
    "args": [
      "up",
      "-d"
    ],
    "healthcheck": "http://127.0.0.1:3000/"
  },
  "stop": {
    "strategy": "docker-compose",
    "args": [
      "stop"
    ]
  },
  "dashboard": {
    "strategy": "url",
    "url": "http://127.0.0.1:3000/"
  },
  "logs": {
    "strategy": "docker-compose-logs",
    "tail": 200
  },
  "secrets": [],
  "permissions": [
    {
      "type": "network",
      "level": "local",
      "description": "Opens a local web UI on 127.0.0.1:3000."
    }
  ]
}